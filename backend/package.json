{
  "name": "yieldvault-backend",
  "version": "1.0.0",
  "description": "YieldVault Stellar RWA Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:smoke": "npm run build && npm run start &",
    "lint": "eslint src",
    "format": "prettier --write src",
    "check:migrations": "node scripts/check-migrations.js",
    "ci:governance": "npm run lint && npm run test && npm run build && npm run check:migrations",
    "generate:openapi": "tsx scripts/generate-openapi.ts"
  },
  "keywords": [
    "stellar",
    "vault",
    "rwa",
    "yield"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "node-cache": "^5.1.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^2.0.12",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.40.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "tsx": "^4.0.0",
    "typescript": "^5.1.0"
  }
}
